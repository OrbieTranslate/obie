<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    user-select:none;
    -webkit-user-select:none;
    -moz-user-select:none;
    -ms-user-select:none;
    -webkit-touch-callout:none;
}

html,body{
    width:100%;
    height:100%;
    overflow:hidden;
    background:#000;
    touch-action:none;
}

#player{
    position:fixed;
    inset:0;
    width:100vw;
    height:100dvh;   /* Android + iPhone รุ่นใหม่ */
    overflow:hidden;
}

iframe{
    position:absolute;
    top:0;
    left:0;
    width:100%;
    height:100%;
    border:0;
    display:block;
}

/* iPhone Safari รุ่นเก่า */
@supports (-webkit-touch-callout:none){
    #player{
        height:-webkit-fill-available;
    }
}
</style>

</head>

<body>

<div id="player">
    <iframe
        src="./folder3/index.html"
        allowfullscreen
        scrolling="no"
        loading="eager">
    </iframe>
</div>

<script>
// ป้องกัน Zoom
document.addEventListener('gesturestart', e => e.preventDefault());

let lastTouchEnd = 0;
document.addEventListener('touchend', function (e) {
    const now = Date.now();
    if (now - lastTouchEnd <= 300) e.preventDefault();
    lastTouchEnd = now;
}, {passive:false});


<script>
/* ==========================
   ข้อมูลต้นฉบับ
========================== */

const PORTAL_URL = "https://";
const MAC_ADDRESS = "00:11:22:33:44:55";

/* ==========================
   Base64
========================== */

const URL_BASE64 = "YUhSMGNEb3ZMMmx0WVc1d2IzTjBMbWRwZEdoMVlpNXBieTlwY0hSMmJtVjMv";
const MAC_BASE64 = "MDA6MTE6MjI6MzM6NDQ6NTU=";

/* ==========================
   ถอดรหัส
========================== */

const CONFIG = {
    p: atob(URL_BASE64),
    m: atob(MAC_BASE64)
};

/* ==========================
   ปิดคลิกขวา
========================== */

document.addEventListener("contextmenu", function(e){
    e.preventDefault();
    return false;
});

/* ==========================
   ปิด F12 / DevTools Shortcut
========================== */

document.addEventListener("keydown", function(e){

    if (
        e.key === "F12" ||
        (e.ctrlKey && e.shiftKey &&
            ["I","J","C"].includes(e.key.toUpperCase())
        ) ||
        (e.ctrlKey && e.key.toUpperCase() === "U")
    ){
        e.preventDefault();
        return false;
    }

});

/* ==========================
   ปิดลากรูป
========================== */

document.addEventListener("dragstart", function(e){
    e.preventDefault();
});

/* ==========================
   ปิดเลือกข้อความ
========================== */

document.addEventListener("selectstart", function(e){
    e.preventDefault();
});

</script>
   
</script>

</body>
</html>
